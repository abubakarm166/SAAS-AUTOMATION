[Unit]
Description=SnapShot Next.js Dashboard
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/SAAS-AUTOMATION/frontend
Environment=NODE_ENV=production
EnvironmentFile=-/home/ubuntu/SAAS-AUTOMATION/frontend/.env.local
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
